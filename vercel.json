{
  "redirects": [
    {
      "source": "/app/terms-of-service",
      "destination": "https://app.muxday.com/terms-of-service",
      "permanent": true
    },
    {
      "source": "/app/privacy-policy",
      "destination": "https://app.muxday.com/privacy-policy",
      "permanent": true
    },
    {
      "source": "/invite/:path*",
      "destination": "https://app.muxday.com/invite/",
      "permanent": true
    },
    {
      "source": "/:name",
      "destination": "https://app.muxday.com?user=:name",
      "permanent": true
    }
  ]
}