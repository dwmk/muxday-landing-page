{
  "rewrites": [
    // 1. Root → landing (highest priority)
    {
      "source": "/",
      "destination": "/landing.html"
    },

    // 2. Any real .html file (future: terms-of-service.html, etc.)
    {
      "source": "/:path*.html",
      "destination": "/:path*.html"
    },

    // 3. Protect build artifacts & static assets
    {
      "source": "/src/:path*",
      "destination": "/src/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/vite.svg",
      "destination": "/vite.svg"
    },

    // 4. VERY IMPORTANT – negative lookahead to exclude paths that should NOT go to SPA
    //    (add more patterns here later if you create API routes, /admin, etc.)
    {
      "source": "/((?!src|assets|vite\\.svg|\\w+\\.html$).*)",
      "destination": "/index.html"
    }
  ]
}